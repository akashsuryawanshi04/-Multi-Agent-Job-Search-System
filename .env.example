# ============================================================
# Job Search AI — Environment Variables Template
# ============================================================
# INSTRUCTIONS:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in YOUR values in the .env file
#   3. NEVER commit the .env file to Git
#   4. This file (.env.example) IS safe to commit
# ============================================================


# ------------------------------------------------------------
# APPLICATION SETTINGS
# ------------------------------------------------------------

# Environment: development | staging | production
APP_ENV=development

# App name (used in logs and email subjects)
APP_NAME="Job Search AI"

# Version tag
APP_VERSION=1.0.0

# Backend server host and port
APP_HOST=0.0.0.0
APP_PORT=8000

# Set to False in production
DEBUG=True

# Comma-separated list of allowed frontend origins
# Example: http://localhost:5173,https://yourdomain.com
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000


# ------------------------------------------------------------
# ANTHROPIC (CLAUDE AI)
# ------------------------------------------------------------
# Get your key from: https://console.anthropic.com/
# Used by: backend/services/llm_service.py
#          All 8 agents in backend/agents/

ANTHROPIC_API_KEY=sk-ant-your-key-here

# Claude model to use for all agents
# Options: claude-opus-4-5, claude-sonnet-4-5, claude-haiku-4-5
ANTHROPIC_MODEL=claude-sonnet-4-5

# Max tokens Claude returns per agent call
ANTHROPIC_MAX_TOKENS=4096

# Timeout in seconds for Claude API calls
ANTHROPIC_TIMEOUT=60

# Max retry attempts if Claude API call fails
ANTHROPIC_MAX_RETRIES=3


# ------------------------------------------------------------
# DATABASE (PostgreSQL)
# ------------------------------------------------------------
# Used by: backend/db/database.py
# Format:  postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DBNAME

DB_HOST=localhost
DB_PORT=5432
DB_NAME=jobsearch_db
DB_USER=postgres
DB_PASSWORD=your_strong_password_here

# Full async connection string (auto-built from above in config.py)
# You can override it directly here if needed
# DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/jobsearch_db

# Sync URL used by Alembic migrations only
# SYNC_DATABASE_URL=postgresql+psycopg2://postgres:password@localhost:5432/jobsearch_db

# Max DB connections in the pool
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20


# ------------------------------------------------------------
# REDIS
# ------------------------------------------------------------
# Used by: Celery task queue + caching
# Install Redis locally or use Redis Cloud (https://redis.io/cloud)

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Full Redis URL (auto-built from above in config.py)
# REDIS_URL=redis://:password@localhost:6379/0


# ------------------------------------------------------------
# CELERY (Async Task Queue)
# ------------------------------------------------------------
# Used by: backend/orchestrator/task_queue.py
# Celery uses Redis as both broker and result backend

CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Max number of worker processes
CELERY_WORKERS=4

# Task timeout in seconds (pipeline should finish within this)
CELERY_TASK_TIMEOUT=300


# ------------------------------------------------------------
# JWT AUTHENTICATION
# ------------------------------------------------------------
# Used by: backend/api/middleware.py
# Generate a secret: openssl rand -hex 32

JWT_SECRET_KEY=your-super-secret-jwt-key-generate-with-openssl
JWT_ALGORITHM=HS256

# Token expiry in minutes
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7


# ------------------------------------------------------------
# FILE UPLOADS
# ------------------------------------------------------------
# Used by: backend/services/pdf_service.py
# Where uploaded resumes are temporarily stored

UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=10

# Allowed file types for resume upload
ALLOWED_FILE_TYPES=pdf,docx,doc


# ------------------------------------------------------------
# JOB SCRAPING — RapidAPI
# ------------------------------------------------------------
# Used by: backend/services/scraper_service.py
# Sign up at: https://rapidapi.com/
# Subscribe to: "JSearch" API (covers LinkedIn, Indeed, Glassdoor)

RAPIDAPI_KEY=your-rapidapi-key-here
RAPIDAPI_HOST=jsearch.p.rapidapi.com

# Base URL for JSearch API
JSEARCH_BASE_URL=https://jsearch.p.rapidapi.com

# Max jobs to fetch per search query
JOB_SEARCH_MAX_RESULTS=50

# Scraping request timeout in seconds
SCRAPER_TIMEOUT=30

# Delay between scraping requests (seconds) — avoids rate limiting
SCRAPER_DELAY=2


# ------------------------------------------------------------
# EMAIL SERVICE
# ------------------------------------------------------------
# Used by: backend/services/email_service.py
# Supports Gmail SMTP or any SMTP provider

MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-gmail-app-password
MAIL_FROM=your-email@gmail.com
MAIL_FROM_NAME="Job Search AI"
MAIL_PORT=587
MAIL_SERVER=smtp.gmail.com
MAIL_STARTTLS=True
MAIL_SSL_TLS=False

# Whether to actually send emails (set False during development)
MAIL_ENABLED=False


# ------------------------------------------------------------
# CORS & SECURITY
# ------------------------------------------------------------

# Trusted hostnames (comma-separated)
TRUSTED_HOSTS=localhost,127.0.0.1

# Whether to enforce HTTPS redirects
FORCE_HTTPS=False


# ------------------------------------------------------------
# LOGGING
# ------------------------------------------------------------
# Used by: backend/utils/logger.py
# Levels: DEBUG | INFO | WARNING | ERROR | CRITICAL

LOG_LEVEL=DEBUG

# Log output: console | file | both
LOG_OUTPUT=both

# Log file path (if LOG_OUTPUT includes file)
LOG_FILE_PATH=logs/app.log

# Max log file size before rotation (MB)
LOG_MAX_SIZE_MB=10

# Number of rotated log files to keep
LOG_BACKUP_COUNT=5


# ------------------------------------------------------------
# NLP MODELS
# ------------------------------------------------------------
# Used by: backend/services/embedding_service.py
# Model is downloaded automatically on first run

# Sentence-transformers model for job matching embeddings
EMBEDDING_MODEL=all-MiniLM-L6-v2

# SpaCy model for Named Entity Recognition in resumes
SPACY_MODEL=en_core_web_sm

# Minimum match score (0.0 to 1.0) to include a job in results
MIN_MATCH_SCORE=0.4


# ------------------------------------------------------------
# PIPELINE SETTINGS
# ------------------------------------------------------------
# Used by: backend/orchestrator/pipeline.py

# Maximum jobs to process through matching per pipeline run
PIPELINE_MAX_JOBS=20

# Whether to run ATS + Cover Letter agents in parallel
PIPELINE_PARALLEL_ENABLED=True

# WebSocket ping interval in seconds
WS_PING_INTERVAL=20
WS_PING_TIMEOUT=10